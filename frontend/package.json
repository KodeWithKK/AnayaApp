{
  "name": "k3-project",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "prebuild": "expo prebuild",
    "pb:android": "expo prebuild -p android --clean",
    "pb:ios": "expo prebuild -p ios --clean",
    "android": "expo run:android",
    "doctor": "expo-doctor",
    "doctor:fix": "npx expo install --fix",
    "expo-update": "expo install expo@latest",
    "update-deps": "expo install --fix",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "clean": "npx rimraf .expo node_modules",
    "format": "prettier --write .",
    "export:apk": "node scripts/export-apk.js --prebuild",
    "export:apk:fast": "node scripts/export-apk.js",
    "postinstall": "npx tailwindcss -i ./global.css -o ./node_modules/.cache/nativewind/global.css"
  },
  "jest": {
