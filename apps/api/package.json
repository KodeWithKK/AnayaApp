{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node build/index",
    "build": "tsc",
    "build:lambda": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --external:pg-native",
    "dev": "tsc-watch --onSuccess \"bun build/index.js\"",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:pull": "npx drizzle-kit pull",
    "db:push": "npx drizzle-kit push",
    "db:studio": "npx drizzle-kit studio",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "ngrok": "ngrok http 8000"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@clerk/express": "^1.3.54",
    "@repo/db": "workspace:*",
    "@vendia/serverless-express": "^4.12.6",
    "bcryptjs": "^3.0.0",
    "chalk": "~4.0.0",
    "cloudinary": "^2.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.9",
    "svix": "^1.62.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "@repo/typescript-config": "workspace:*",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^24.1.0",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.28.1",
    "esbuild": "^0.25.8",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier": "^3.5.1",
    "tsc-watch": "^6.2.1",
    "typescript": "^6.0.2"
  }
}
